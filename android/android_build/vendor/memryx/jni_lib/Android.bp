cc_library_shared {
    name: "memxdriver_jni",
    srcs: [
        "memxdriver_jni.cpp"
    ],

    shared_libs: [
        "liblog",
        "libbinder",
        "libutils",
        "libbinder_ndk",
        "com.memryx.memxdriver.IMemxDriverService-V1-ndk",
    ],

    header_libs: [
        "jni_headers"
    ],

    c_std: "gnu11",
    cpp_std: "c++17",
    cflags: [
        "-Wall",
        "-Werror",
        "-fexceptions",
        "-frtti",
    ],

    vendor: true,
    proprietary: true,
    stem: "libmemxdriver_jni",
    ldflags: [
        "-Wl,-soname,libmemxdriver_jni.so"
    ],
}
