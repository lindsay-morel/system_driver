<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView_dirPathLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DFP Path:"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/editText_dirPath"
        />
    <EditText
        android:id="@+id/editText_dirPath"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter DFP Directory Path"
        android:inputType="textUri"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/textView_dirPathLabel"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/textView_groupIdLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Group ID:"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/spinner_group"
        app:layout_constraintBottom_toBottomOf="@id/spinner_group"
        />
    <Spinner
        android:id="@+id/spinner_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="48dp"
        app:layout_constraintTop_toBottomOf="@id/editText_dirPath"
        app:layout_constraintStart_toEndOf="@id/textView_groupIdLabel"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/textView_framesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Frames:"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/editText_frames"
        />
    <EditText
        android:id="@+id/editText_frames"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Count"
        android:inputType="number"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/spinner_group"
        app:layout_constraintStart_toEndOf="@id/textView_framesLabel"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/textView_hoursLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Run Hours:"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@id/editText_hours"
        />
    <EditText
        android:id="@+id/editText_hours"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="0=single run"
        android:inputType="number"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/editText_frames"
        app:layout_constraintStart_toEndOf="@id/textView_hoursLabel"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/textView_burningLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Single/Burning:"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/toggleButton_burning"
        app:layout_constraintBottom_toBottomOf="@id/toggleButton_burning"
        />
    <ToggleButton
        android:id="@+id/toggleButton_burning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textOff="Single Run"
        android:textOn="Burning Test"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/editText_hours"
        app:layout_constraintStart_toEndOf="@id/textView_burningLabel"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/toggleButton_burning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button
            android:id="@+id/button_start_benchmark"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Run Benchmark"
            android:layout_marginEnd="8dp"
            />
        <Button
            android:id="@+id/button_stop_benchmark"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop"
            android:enabled="false"
            />
    </LinearLayout>

    <ListView
        android:id="@+id/listView_results"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp"
        app:layout_constraintTop_toBottomOf="@id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>